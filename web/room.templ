package web

import (
	"crabspy/sql/sqlcgen"
	"fmt"
)

templ RoomPage(room sqlcgen.Room) {
	@Base(room.Name) {
		<main id="morphTarget" class="items-center" data-init={ fmt.Sprintf("@get('/sse/%d')", room.ID) }>
			<div class="flex-col max-w-content-3 w-full gap-4 mt-4">
				<div class="bg border-2 p-4 shadow-hard">
					<div class="flex items-center uppercase mb-3">
						<span class="text-4xl font-bold color-accent">{ room.Name }</span>
					</div>
					<div class="grid-14">
						<div class="p-3 border-1 bg-primary rounded-2 text-center">
							<div class="text-xs uppercase font-bold mb-2">Locations</div>
							<div class="text-3xl font-bold">{ fmt.Sprintf("%d", room.MaxLocations) }</div>
						</div>
						<div class="p-3 border-1 bg-primary rounded-2 text-center">
							<div class="text-xs uppercase font-bold mb-2">Max Players</div>
							<div class="text-3xl font-bold">{ fmt.Sprintf("%d", room.MaxPlayers) }</div>
						</div>
					</div>
				</div>
			</div>
		</main>
	}
}

// getUserColor returns a deterministic color assignment based on username, claude made it don't judge me.
func getUserColor(username string, css string) templ.SafeCSS {
	colors := []string{
		"#ef4444;", // red
		"#f97316;", // orange
		"#eab308;", // yellow
		"#22c55e;", // green
		"#3b82f6;", // blue
		"#8b5cf6;", // violet
		"#ec4899;", // pink
		"#06b6d4;", // cyan
		"#f59e0b;", // amber
		"#10b981;", // emerald
		"#6366f1;", // indigo
		"#84cc16;", // lime
	}

	hash := 0
	for _, char := range username {
		hash = hash*31 + int(char)
	}

	index := hash % len(colors)
	if index < 0 {
		index = -index
	}
	cssVal := fmt.Sprintf("%s: %s", css, colors[index])

	return templ.SafeCSS(cssVal)
}
