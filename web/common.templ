package web

import "fmt"

templ Error(msg string) {
	<div id="error">{ msg }</div>
}

templ Dialog(id string, title string, body templ.Component) {
	<dialog id={ id } class="dialog relative">
		<div class="flex items-center justify-center gap-2 mb-3">
			<div class="dialog-title">{ title }</div>
			<span
				type="button"
				class="px-2 cursor-pointer font-bold text-lg absolute top-0 right-0"
				data-on:click={ fmt.Sprintf("document.getElementById('%s').close()", id) }
			>
				X	
			</span>
		</div>
		@body
	</dialog>
}

templ PlayerCard(p Player, isHost bool, isPauser bool, isAccused bool, isSpyAndTime0 bool, hasVoted bool) {
	<div
		class={ "player-card shadow " +
			BoolClass(isHost, "is-host") +
			BoolClass(isPauser, "is-pauser") +
			BoolClass(isAccused, "is-accused") +
			BoolClass(hasVoted, "has-voted") +
			BoolClass(isSpyAndTime0, "is-spy") }
		style={ getUserColor(p.Username, "border-color") }
	>
		if isSpyAndTime0 {
			<img
				class="pixelated"
				src={ StaticPath("images/player-crabs/spy-crab.png") }
			/>
		} else {
			<img
				class="pixelated"
				src={ StaticPath(fmt.Sprintf("images/player-crabs/%s", p.CrabAvatar)) }
			/>
		}
		<span
			style={ getUserColor(p.Username, "color") }
			class="player-name"
		>
			{ p.DisplayName }
		</span>
		if isHost {
			<span class="float float-top-left bg color-primary">HOST</span>
		}
		if isPauser {
			<span class="float float-top-right text-outline">ACCUSER</span>
		}
		if isAccused {
			<span class="float float-top-right text-outline">ACCUSED</span>
		}
		if isSpyAndTime0 {
			<span class="float float-top-right text-outline color-primary">SPY</span>
		}
		if hasVoted {
			<span class="float float-bottom-right text-outline color-success">✓</span>
		}
	</div>
}

// getUserColor returns a deterministic color assignment based on username.
func getUserColor(username string, css string) templ.SafeCSS {
	colors := []string{
		"#ef4444;", // red
		"#f97316;", // orange
		"#eab308;", // yellow
		"#22c55e;", // green
		"#3b82f6;", // blue
		"#8b5cf6;", // violet
		"#ec4899;", // pink
		"#06b6d4;", // cyan
		"#f59e0b;", // amber
		"#10b981;", // emerald
		"#6366f1;", // indigo
		"#84cc16;", // lime
	}

	hash := 0
	for _, char := range username {
		hash = hash*31 + int(char)
	}

	index := hash % len(colors)
	if index < 0 {
		index = -index
	}
	cssVal := fmt.Sprintf("%s: %s", css, colors[index])

	return templ.SafeCSS(cssVal)
}

func BoolClass(cond bool, name string) string {
	if cond {
		return name + " "
	}
	return ""
}

templ ScoreSVG() {
	<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
		<line x1="18" y1="20" x2="18" y2="10"></line>
		<line x1="12" y1="20" x2="12" y2="4"></line>
		<line x1="6" y1="20" x2="6" y2="14"></line>
	</svg>
}

templ HistorySVG() {
	<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
		<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
		<path d="M3 3v5h5"></path>
		<path d="M12 7v5l4 2"></path>
	</svg>
}

templ LocationsSVG() {
